{
  "name": "homebug",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worker": "wrangler pages dev .vercel/output/static",
    "build": "next build",
    "build:pages": "npx @cloudflare/next-on-pages",
    "deploy": "npm run build:pages && wrangler pages deploy .vercel/output/static",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply homebug-db --local",
    "db:migrate": "wrangler d1 migrations apply homebug-db --remote",
    "db:migrate:status": "wrangler d1 migrations list homebug-db --remote"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@heroui/react": "^3.0.2",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "15.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "swr": "^2.4.1",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260415.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.82.2"
  }
}