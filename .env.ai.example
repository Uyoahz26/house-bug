# AI 配置示例
# 复制此文件为 .env.local 并填写实际的 API Key

# ============================================================
# DeepSeek 配置（推荐，性价比高）
# ============================================================
# 官网: https://platform.deepseek.com/
# 价格: 输入 ¥0.001/千tokens，输出 ¥0.002/千tokens
# 单次识别成本: 约 ¥0.002（0.2 分）

AI_PROVIDER=deepseek
AI_MODEL=deepseek-chat
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI_API_BASE=  # 留空使用默认端点

# ============================================================
# 豆包配置（字节跳动，国内访问快）
# ============================================================
# 官网: https://www.volcengine.com/products/doubao
# 需要在火山引擎创建推理接入点

# AI_PROVIDER=doubao
# AI_MODEL=doubao-pro-32k
# AI_API_KEY=your-doubao-api-key
# AI_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# ============================================================
# OpenAI 配置（识别准确度高）
# ============================================================
# 官网: https://platform.openai.com/
# 价格: 输入 $0.15/百万tokens，输出 $0.60/百万tokens

# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI_API_BASE=  # 留空使用默认端点

# ============================================================
# Anthropic (Claude) 配置（安全性高）
# ============================================================
# 官网: https://www.anthropic.com/
# 价格: 输入 $0.80/百万tokens，输出 $4.00/百万tokens

# AI_PROVIDER=anthropic
# AI_MODEL=claude-3-5-haiku-20241022
# AI_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI_API_BASE=  # 留空使用默认端点

# ============================================================
# 自定义配置（本地部署或其他兼容 OpenAI API 的服务）
# ============================================================
# 例如: Ollama, LM Studio, vLLM 等

# AI_PROVIDER=custom
# AI_MODEL=llama3.2-vision
# AI_API_KEY=not-needed  # 本地部署可能不需要
# AI_API_BASE=http://localhost:11434/v1

# ============================================================
# 通用参数
# ============================================================
AI_TEMPERATURE=0.1          # 温度参数（0-1），越低越确定
AI_MAX_TOKENS=2000          # 最大输出 token 数
AI_TIMEOUT=30000            # 请求超时时间（毫秒）

# ============================================================
# 注意事项
# ============================================================
# 1. 这些配置也可以在系统设置页面中配置，无需使用环境变量
# 2. 系统设置优先级高于环境变量
# 3. API Key 是敏感信息，请勿提交到代码仓库
# 4. 建议使用 DeepSeek，性价比最高
